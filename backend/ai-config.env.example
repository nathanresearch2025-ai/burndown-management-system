# AI 功能环境变量配置示例
# 将此文件复制为 .env 并填入实际值

# 启用 AI 功能
AI_ENABLED=true

# LLM API 配置
# OpenAI 兼容的 API 端点
AI_BASE_URL=https://api.openai.com/v1/chat/completions

# API 密钥
AI_API_KEY=your-api-key-here

# 模型名称（例如：gpt-4, gpt-3.5-turbo, claude-3-5-sonnet-20241022）
AI_CHAT_MODEL=gpt-4

# 请求超时时间（默认 30 秒）
AI_TIMEOUT=30s

# 最大相似任务数量（默认 5）
AI_MAX_SIMILAR_TASKS=5

# 速率限制配置
# 每用户每小时最大请求数（默认 10）
AI_RATE_LIMIT_MAX_REQUESTS=10

# 速率限制时间窗口（分钟，默认 60）
AI_RATE_LIMIT_WINDOW_MINUTES=60

# 使用说明：
# 1. 复制此文件为 .env
# 2. 填入实际的 API 密钥和配置
# 3. 在 Docker Compose 或 Kubernetes 中加载环境变量
# 4. 重启应用使配置生效

# 注意事项：
# - 请勿将包含真实 API 密钥的 .env 文件提交到版本控制
# - 生产环境建议使用密钥管理服务（如 AWS Secrets Manager）
# - 定期轮换 API 密钥以提高安全性
