		{
			"name": "Performance Testing",
			"item": [
				{
					"name": "性能测试 - 单次请求",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"const responseTime = pm.response.responseTime;",
									"console.log(\"Response time: \" + responseTime + \"ms\");",
									"",
									"pm.test(\"Response time is acceptable\", function () {",
									"    // P95 目标 < 8000ms",
									"    pm.expect(responseTime).to.be.below(8000);",
									"});",
									"",
									"// 记录到环境变量用于统计",
									"let responseTimes = pm.environment.get('responseTimes') || [];",
									"responseTimes.push(responseTime);",
									"pm.environment.set('responseTimes', responseTimes);",
									"",
									"// 如果是最后一次迭代，计算统计数据",
									"const iteration = pm.info.iteration;",
									"const totalIterations = pm.info.iterationCount;",
									"",
									"if (iteration === totalIterations - 1) {",
									"    responseTimes.sort((a, b) => a - b);",
									"    const count = responseTimes.length;",
									"    const sum = responseTimes.reduce((a, b) => a + b, 0);",
									"    const avg = sum / count;",
									"    const p50 = responseTimes[Math.floor(count * 0.5)];",
									"    const p95 = responseTimes[Math.floor(count * 0.95)];",
									"    const p99 = responseTimes[Math.floor(count * 0.99)];",
									"    const min = responseTimes[0];",
									"    const max = responseTimes[count - 1];",
									"    ",
									"    console.log('\\n=== Performance Statistics ===');",
									"    console.log('Total requests: ' + count);",
									"    console.log('Average: ' + avg.toFixed(2) + 'ms');",
									"    console.log('Min: ' + min + 'ms');",
									"    console.log('Max: ' + max + 'ms');",
									"    console.log('P50: ' + p50 + 'ms');",
									"    console.log('P95: ' + p95 + 'ms');",
									"    console.log('P99: ' + p99 + 'ms');",
									"    console.log('==============================\\n');",
									"    ",
									"    // 清空统计数据",
									"    pm.environment.unset('responseTimes');",
									"}"
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"// 生成唯一 traceId",
									"const traceId = 'perf-' + Date.now() + '-' + pm.info.iteration;",
									"pm.variables.set('traceId', traceId);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"question\": \"今天的站会总结\",\n  \"projectId\": {{projectId}},\n  \"sprintId\": {{sprintId}},\n  \"userId\": {{userId}},\n  \"traceId\": \"{{traceId}}\"\n}"
						},
						"url": {
							"raw": "{{langchainUrl}}/agent/standup/query",
							"host": [
								"{{langchainUrl}}"
							],
							"path": [
								"agent",
								"standup",
								"query"
							]
						},
						"description": "性能测试请求\n\n使用方法：\n1. 在 Collection Runner 中运行\n2. 设置 Iterations 为 50-100\n3. 查看控制台输出的统计数据"
					},
					"response": []
				}
			],
			"description": "性能测试相关请求"
		},
