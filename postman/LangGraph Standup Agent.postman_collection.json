							"var json = pm.response.json();",
							"console.log('=== ReAct Chain Trace ===');",
							"console.log('Tools Used:', JSON.stringify(json.toolsUsed));",
							"console.log('Evidence Count:', json.evidence.length);",
							"console.log('Risk Level:', json.riskLevel);",
							"json.evidence.forEach(function(ev, i) {",
							"    console.log('Evidence['+i+']:', JSON.stringify(ev).substring(0,100));",
							"});"
