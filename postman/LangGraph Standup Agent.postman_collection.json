		{
			"name": "langgraph_v2 - ReAct 多工具链路追踪",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Status code is 200', function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"pm.test('Multiple tools used in ReAct loop', function () {",
							"    var json = pm.response.json();",
							"    pm.expect(json.toolsUsed).to.be.an('array').with.lengthOf.at.least(1);",
