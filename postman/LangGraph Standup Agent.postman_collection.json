{
	"info": {
		"_postman_id": "langgraph-standup-agent-v2",
		"name": "LangGraph Standup Agent",
		"description": "LangGraph 多 Agent 站会问答 API 测试集合\n\n支持四种 pipeline 模式：\n- fast：并行工具 + 单次 LLM 汇总\n- legacy：4 Agent 串行\n- langgraph：确定性工作流图\n- langgraph_v2：Supervisor + DataAgent(ReAct) + AnalystAgent + WriterAgent\n\n切换模式：修改 .env 中的 STANDUP_PIPELINE_MODE",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8091",
			"type": "string",
			"description": "LangChain Python 服务地址，端口见 .env LANGCHAIN_SERVICE_PORT"
		},
		{
			"key": "project_id",
			"value": "1",
			"type": "string"
		},
		{
			"key": "sprint_id",
			"value": "2",
			"type": "string"
		},
		{
			"key": "user_id",
			"value": "1",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "langgraph_v2 - 标准站会问答",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Status code is 200', function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"pm.test('Response has answer field', function () {",
							"    var json = pm.response.json();",
							"    pm.expect(json).to.have.property('answer');",
							"    pm.expect(json.answer).to.be.a('string').and.not.empty;",
							"});",
							"pm.test('Response has toolsUsed array', function () {",
							"    var json = pm.response.json();",
							"    pm.expect(json.toolsUsed).to.be.an('array');",
							"});",
							"pm.test('Response has riskLevel field', function () {",
							"    var json = pm.response.json();",
							"    pm.expect(json).to.have.property('riskLevel');",
							"});",
							"pm.test('Response has evidence array', function () {",
							"    var json = pm.response.json();",
							"    pm.expect(json.evidence).to.be.an('array');",
							"});",
							"pm.test('Response time < 60s', function () {",
							"    pm.expect(pm.response.responseTime).to.be.below(60000);",
							"});",
							"console.log('Answer:', pm.response.json().answer.substring(0,200));",
							"console.log('Risk Level:', pm.response.json().riskLevel);",
							"console.log('Tools Used:', JSON.stringify(pm.response.json().toolsUsed));",
							"console.log('Evidence Count:', pm.response.json().evidence.length);",
							"console.log('Response time:', pm.response.responseTime, 'ms');"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [{"key": "Content-Type", "value": "application/json"}],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"question\": \"当前冲刺的进展如何？有哪些风险需要关注？\",\n    \"projectId\": {{project_id}},\n    \"sprintId\": {{sprint_id}},\n    \"userId\": {{user_id}},\n    \"traceId\": \"test-langgraph-v2-001\"\n}",
					"options": {"raw": {"language": "json"}}
				},
				"url": {
					"raw": "{{base_url}}/agent/standup/query",
					"host": ["{{base_url}}"],
					"path": ["agent", "standup", "query"]
				},
				"description": "langgraph_v2 标准站会问答\n\n触发完整的 Supervisor → DataAgent(ReAct) → AnalystAgent → WriterAgent 流程\n\n需在 .env 中设置：STANDUP_PIPELINE_MODE=langgraph_v2"
			},
			"response": []
		},
		{
			"name": "langgraph_v2 - 燃尽风险专项分析",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Status code is 200', function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"pm.test('riskLevel is valid', function () {",
							"    var json = pm.response.json();",
							"    var valid = ['LOW','MEDIUM','HIGH','CRITICAL','UNKNOWN',null];",
							"    pm.expect(valid).to.include(json.riskLevel);",
							"});",
							"pm.test('Evidence contains data', function () {",
							"    pm.expect(pm.response.json().evidence).to.be.an('array');",
							"});",
							"console.log('Risk Level:', pm.response.json().riskLevel);",
							"console.log('Tools Used:', pm.response.json().toolsUsed);",
							"console.log('Answer preview:', pm.response.json().answer.substring(0,200));"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [{"key": "Content-Type", "value": "application/json"}],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"question\": \"当前冲刺的燃尽情况是否存在延期风险？请给出详细的风险评估。\",\n    \"projectId\": {{project_id}},\n    \"sprintId\": {{sprint_id}},\n    \"userId\": {{user_id}},\n    \"traceId\": \"test-risk-analysis-001\"\n}",
					"options": {"raw": {"language": "json"}}
				},
				"url": {
					"raw": "{{base_url}}/agent/standup/query",
					"host": ["{{base_url}}"],
					"path": ["agent", "standup", "query"]
				},
				"description": "专注于燃尽风险评估，DataAgent ReAct 应调用 evaluateBurndownRisk 工具\n\n预期 riskLevel 返回 LOW / MEDIUM / HIGH / CRITICAL"
			},
			"response": []
		},
