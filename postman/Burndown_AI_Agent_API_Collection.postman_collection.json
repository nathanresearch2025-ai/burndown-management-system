{
	"info": {
		"_postman_id": "burndown-ai-agent-collection",
		"name": "Burndown AI Agent API",
		"description": "AI Agent API collection for Burndown Management System - Standup Assistant and LangChain Integration",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://159.75.202.106:30080/api/v1",
			"type": "string"
		},
		{
			"key": "token",
			"value": "",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Standup Agent",
			"description": "Scrum 站会助手 - 基于 AI 的站会问答系统",
			"item": [
				{
					"name": "Standup Query",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"question\": \"今天有哪些进行中的任务？\",\n  \"projectId\": 1,\n  \"sprintId\": 1,\n  \"userId\": 1\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/agent/standup/query",
							"host": ["{{baseUrl}}"],
							"path": ["agent", "standup", "query"]
						},
						"description": "处理站会相关问题，返回基于 AI 的回答。支持查询任务状态、燃尽图、风险评估等。"
					}
				},
				{
					"name": "Standup Query - Task Progress",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"question\": \"当前 Sprint 的任务进度如何？\",\n  \"projectId\": 1,\n  \"sprintId\": 1,\n  \"userId\": 1\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/agent/standup/query",
							"host": ["{{baseUrl}}"],
							"path": ["agent", "standup", "query"]
						},
						"description": "查询当前 Sprint 的任务进度"
					}
				},
				{
					"name": "Standup Query - Burndown Status",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"question\": \"燃尽图显示的进度如何？有风险吗？\",\n  \"projectId\": 1,\n  \"sprintId\": 1,\n  \"userId\": 1\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/agent/standup/query",
							"host": ["{{baseUrl}}"],
							"path": ["agent", "standup", "query"]
						},
						"description": "查询燃尽图状态和风险评估"
					}
				},
				{
					"name": "Standup Query - My Tasks",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"question\": \"我今天需要完成哪些任务？\",\n  \"projectId\": 1,\n  \"sprintId\": 1,\n  \"userId\": 3\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/agent/standup/query",
							"host": ["{{baseUrl}}"],
							"path": ["agent", "standup", "query"]
						},
						"description": "查询特定用户的任务列表"
					}
				}
			]
		},
