		{
			"name": "2. Basic Similarity Search",
			"item": [
				{
					"name": "Search Similar Tasks - Login Related",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Response has tasks array\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('tasks');",
									"    pm.expect(jsonData.tasks).to.be.an('array');",
									"});",
									"",
									"pm.test(\"Found similar tasks\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.count).to.be.above(0);",
									"});",
									"",
									"pm.test(\"Tasks have similarity scores\", function () {",
									"    var jsonData = pm.response.json();",
									"    if (jsonData.tasks.length > 0) {",
									"        pm.expect(jsonData.tasks[0]).to.have.property('similarityScore');",
									"        pm.expect(jsonData.tasks[0].similarityScore).to.be.a('number');",
									"    }",
									"});",
									"",
									"pm.test(\"Similarity scores are in valid range\", function () {",
									"    var jsonData = pm.response.json();",
									"    jsonData.tasks.forEach(function(task) {",
									"        pm.expect(task.similarityScore).to.be.at.least(-1);",
									"        pm.expect(task.similarityScore).to.be.at.most(1);",
									"    });",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"projectId\": 1,\n    \"title\": \"用户登录优化\",\n    \"description\": \"改进用户登录流程，提升用户体验\",\n    \"type\": \"FEATURE\",\n    \"priority\": \"HIGH\",\n    \"limit\": 5\n}"
						},
