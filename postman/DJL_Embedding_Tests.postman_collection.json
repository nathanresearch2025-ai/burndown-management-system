			"item": [
				{
					"name": "Get Embedding Provider Info",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Response has provider info\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('provider');",
									"    pm.expect(jsonData).to.have.property('status');",
									"});",
									"",
									"pm.test(\"Provider is DJL\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.provider).to.eql('djl');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/embeddings/info",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"embeddings",
								"info"
							]
						},
						"description": "获取当前向量服务的配置信息，包括提供者类型、模型名称、引擎类型和加载状态"
					},
					"response": []
				}
			],
			"description": "向量服务管理相关接口"
		},
